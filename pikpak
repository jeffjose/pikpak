AUTH_BASE = "https://user.mypikpak.com"
API_BASE = "https://api-drive.mypikpak.com"

SCRIPT_DIR = Path(__file__).resolve().parent
ENV_FILE = SCRIPT_DIR / ".env"
TOKEN_CACHE = Path.home() / ".cache" / "pikpak" / "tokens.json"
RECENT_DIRS = Path.home() / ".cache" / "pikpak" / "recent_dirs.json"
MAX_RECENT = 20


def load_recent_dirs():
    if RECENT_DIRS.exists():
        return json.loads(RECENT_DIRS.read_text())
    return []


def save_recent_dir(folder_name):
    dirs = load_recent_dirs()
    if folder_name in dirs:
        dirs.remove(folder_name)
    dirs.insert(0, folder_name)
    dirs = dirs[:MAX_RECENT]
    RECENT_DIRS.parent.mkdir(parents=True, exist_ok=True)
    RECENT_DIRS.write_text(json.dumps(dirs, indent=2))


def load_env():
    """Load key=value pairs from .env file."""
    env = {}
    if ENV_FILE.exists():
        for line in ENV_FILE.read_text().splitlines():
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            key, _, value = line.partition("=")
            env[key.strip()] = value.strip()
    return env


def load_config():
    env = load_env()
    username = os.environ.get("PIKPAK_USERNAME") or env.get("PIKPAK_USERNAME")
    password = os.environ.get("PIKPAK_PASSWORD") or env.get("PIKPAK_PASSWORD")

    if not username or not password:
        print("Missing PIKPAK_USERNAME or PIKPAK_PASSWORD.")
        print(f"Set them in {ENV_FILE} or as environment variables.")
        sys.exit(1)

    return {
        "username": username,
        "password": password,
        "device_id": env.get("PIKPAK_DEVICE_ID", str(uuid.uuid4())),
    }


def load_tokens():
    if TOKEN_CACHE.exists():
        return json.loads(TOKEN_CACHE.read_text())
    return None


def save_tokens(tokens):
    TOKEN_CACHE.parent.mkdir(parents=True, exist_ok=True)
    TOKEN_CACHE.write_text(json.dumps(tokens, indent=2))
    TOKEN_CACHE.chmod(0o600)


def get_captcha_token(device_id, username):
    resp = httpx.post(
        f"{AUTH_BASE}/v1/shield/captcha/init",
        json={
            "client_id": CLIENT_ID,
            "action": "POST:/v1/auth/signin",
            "device_id": device_id,
            "captcha_token": "",
            "meta": {"email": username},
        },
    )
    resp.raise_for_status()
    return resp.json().get("captcha_token", "")


def login(config):
    captcha_token = get_captcha_token(config["device_id"], config["username"])
    resp = httpx.post(
        f"{AUTH_BASE}/v1/auth/signin",
        json={
            "client_id": CLIENT_ID,
            "client_secret": CLIENT_SECRET,
            "username": config["username"],
            "password": config["password"],
            "captcha_token": captcha_token,
        },
    )
    resp.raise_for_status()
    data = resp.json()
    tokens = {
        "access_token": data["access_token"],
        "refresh_token": data["refresh_token"],
        "expires_at": time.time() + data.get("expires_in", 86400) - 60,
    }
    save_tokens(tokens)
    return tokens


def do_refresh(tokens):
    resp = httpx.post(
        f"{AUTH_BASE}/v1/auth/token",
        json={
            "client_id": CLIENT_ID,
            "client_secret": CLIENT_SECRET,
            "grant_type": "refresh_token",
            "refresh_token": tokens["refresh_token"],
        },
    )
    resp.raise_for_status()
    data = resp.json()
    new_tokens = {
        "access_token": data["access_token"],
        "refresh_token": data.get("refresh_token", tokens["refresh_token"]),
        "expires_at": time.time() + data.get("expires_in", 86400) - 60,
    }
    save_tokens(new_tokens)
    return new_tokens


def get_access_token(config):
    tokens = load_tokens()
    if tokens is None:
        print("Logging in...")
        tokens = login(config)
    elif time.time() > tokens["expires_at"]:
        print("Refreshing token...")
        try:
            tokens = do_refresh(tokens)
        except Exception:
            print("Refresh failed, logging in again...")
            tokens = login(config)
    return tokens["access_token"]


def list_files(access_token, parent_id=None):
    params = {"page_size": 100}
    if parent_id:
        params["parent_id"] = parent_id
    resp = httpx.get(
        f"{API_BASE}/drive/v1/files",
        headers={"Authorization": f"Bearer {access_token}"},
        params=params,
    )
    if resp.status_code == 404:
        return []
    resp.raise_for_status()
    return resp.json().get("files", [])


def find_folder(access_token, name, parent_id=None):
    files = list_files(access_token, parent_id)
    for f in files:
        if f["kind"] == "drive#folder" and f["name"] == name:
            return f["id"]
    return None


def find_folder_by_path(access_token, path):
    parts = path.strip("/").split("/")
    parent_id = None
    for part in parts:
        parent_id = find_folder(access_token, part, parent_id)
        if parent_id is None:
            return None
    return parent_id


def create_folder(access_token, name):
    resp = httpx.post(
        f"{API_BASE}/drive/v1/files",
        headers={"Authorization": f"Bearer {access_token}"},
        json={"kind": "drive#folder", "name": name},
    )
    resp.raise_for_status()
    return resp.json()["file"]["id"]


def submit_magnet(access_token, magnet, folder_id):
    resp = httpx.post(
        f"{API_BASE}/drive/v1/files",
        headers={"Authorization": f"Bearer {access_token}"},
        json={
            "kind": "drive#file",
            "upload_type": "UPLOAD_TYPE_URL",
            "url": {"url": magnet},
            "parent_id": folder_id,
        },
    )
    resp.raise_for_status()
    return resp.json()


class _MagnetParser(HTMLParser):
    def __init__(self):
        super().__init__()
        self.results = []  # list of (title, magnet_url)
        self._magnet = None
        self._texts = []
        self._in_torrent_name = False
        self._torrent_name = None

    def handle_starttag(self, tag, attrs):
        attrs_dict = dict(attrs)
        classes = attrs_dict.get("class", "").split()
        if tag == "div" and "torrent_name" in classes:
            self._in_torrent_name = True
            self._texts = []
        if tag == "a":
            href = attrs_dict.get("href", "")
            if href.startswith("magnet:"):
                self._magnet = href
                self._texts = []

    def handle_data(self, data):
        if self._magnet is not None:
            self._texts.append(data)
        elif self._in_torrent_name:
            self._texts.append(data)

    def handle_endtag(self, tag):
        if tag == "div" and self._in_torrent_name:
            name = "".join(self._texts).strip()
            if name:
                self._torrent_name = name
            self._texts = []
            self._in_torrent_name = False
        if tag == "a" and self._magnet is not None:
            text = " ".join(self._texts).strip()
            # If the link text is just a truncated magnet URL, use the
            # torrent_name we captured earlier or fall back to dn= param
            if text.startswith("magnet:"):
                text = ""
            title = text or self._torrent_name or ""
            self.results.append((title, self._magnet))
            self._magnet = None
            self._torrent_name = None


def _label_from_magnet(magnet):
    dn = re.search(r"[&?]dn=([^&]+)", magnet)
    if dn:
        return unquote_plus(dn.group(1))
    return magnet[:80]


def extract_magnets(text):
    """Return list of (title, magnet_url) pairs, deduped by URL."""
    parser = _MagnetParser()
    try:
        parser.feed(text)
    except Exception:
        pass

    if parser.results:
        seen = {}
        for title, magnet in parser.results:
            if magnet not in seen:
                seen[magnet] = title or _label_from_magnet(magnet)
        return [(title, magnet) for magnet, title in seen.items()]

    # fallback: plain text / no HTML anchor tags found
    pattern = r"magnet:\?[^\s\"'<>\]]+"
    magnets = list(dict.fromkeys(re.findall(pattern, text)))
    return [(_label_from_magnet(m), m) for m in magnets]


FETCH_HEADERS = {
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64; rv:128.0) Gecko/20100101 Firefox/128.0",
    "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
    "Accept-Language": "en-US,en;q=0.5",
}

CAPTCHA_HINTS = ["captcha", "challenge", "cf-browser-verification", "just a moment"]


def _looks_like_captcha(text):
    lower = text.lower()
    return any(hint in lower for hint in CAPTCHA_HINTS)


def fetch_url(url, retries=2, delay=3):
    """Fetch a URL with retries. Returns HTML text or exits on failure."""
    last_err = None
    for attempt in range(1, retries + 1):
        try:
            resp = httpx.get(
                url,
                headers=FETCH_HEADERS,
                follow_redirects=True,
                timeout=20,
            )
            if resp.status_code == 200 and not _looks_like_captcha(resp.text):
                return resp.text
            if _looks_like_captcha(resp.text):
                last_err = f"bot protection/CAPTCHA on attempt {attempt}"
                print(f"  Attempt {attempt}/{retries}: blocked by bot protection (status {resp.status_code})")
            else:
                last_err = f"HTTP {resp.status_code}"
                print(f"  Attempt {attempt}/{retries}: HTTP {resp.status_code}")
        except httpx.TimeoutException:
            last_err = "timeout"
            print(f"  Attempt {attempt}/{retries}: timed out")
        except httpx.RequestError as e:
            last_err = str(e)
            print(f"  Attempt {attempt}/{retries}: {e}")
        if attempt < retries:
            print(f"  Retrying in {delay}s...")
            time.sleep(delay)
    return None


def fetch_urls(urls):
    """Fetch multiple URLs, combine their HTML. Returns combined text."""
    all_text = []
    failed = []
    for url in urls:
        print(f"Fetching {url} ...")
        text = fetch_url(url)
        if text:
            all_text.append(text)
            print(f"  OK ({len(text)} bytes)")
        else:
            failed.append(url)
            print(f"  Failed — skipping")
    if failed and not all_text:
        print(f"\nAll URLs failed. The site may be blocking automated requests.")
        print(f"Tip: save the page manually and use -f <file> instead.")
        sys.exit(1)
    if failed:
        print(f"\nWarning: {len(failed)}/{len(urls)} URL(s) failed, continuing with successful ones.")
    return "\n".join(all_text)


def cmd_ls(path=None):
    config = load_config()
    try:
        access_token = get_access_token(config)
    except httpx.HTTPStatusError as e:
        print(f"Login failed: {e.response.status_code} {e.response.json().get('error_description', e.response.text)}")
        sys.exit(1)

    parent_id = None
    if path:
        parent_id = find_folder_by_path(access_token, path)
        if parent_id is None:
            print(f"Folder '{path}' not found.")
            sys.exit(1)

    files = list_files(access_token, parent_id)
    if not files:
        print("(empty)")
        return
    for f in files:
        kind = "d" if f["kind"] == "drive#folder" else "f"
        print(f"[{kind}] {f['name']}")


def cmd_login():
    config = load_config()
    print(f"Logging in as {config['username']}...")
    try:
        login(config)
        print("Login successful.")
    except httpx.HTTPStatusError as e:
        print(f"Login failed: {e.response.status_code} {e.response.json().get('error_description', e.response.text)}")
        sys.exit(1)


def _get_auth_blocking(config):
    """Run in a thread: returns access_token or raises."""
    return get_access_token(config)


def main():
    if len(sys.argv) < 2:
        recent = load_recent_dirs()
        if not recent:
            print("No recently used directories.", file=sys.stderr)
            print("Usage: pikpak <folder>", file=sys.stderr)
            sys.exit(1)
        folder_name = questionary.select(
            "Select a recent directory:",
            choices=recent,
        ).ask()
        if not folder_name:
            sys.exit(0)
        sys.argv = [sys.argv[0], folder_name]

    if sys.argv[1] == "login":
        cmd_login()
        return

    if sys.argv[1] == "ls":
        cmd_ls(sys.argv[2] if len(sys.argv) > 2 else None)
        return

    # Parse flags (can appear before or after folder name)
    args = sys.argv[1:]
    file_path = None
    urls = None
    select_all = False
    auto_yes = False
    remaining = []
    i = 0
    while i < len(args):
        if args[i] in ("-f", "--file"):
            if i + 1 >= len(args):
                print("Usage: pikpak <folder> -f <file>", file=sys.stderr)
                sys.exit(1)
            file_path = args[i + 1]
            i += 2
        elif args[i] == "--url":
            if i + 1 >= len(args):
                print("Usage: pikpak <folder> --url <url1> [url2] ...", file=sys.stderr)
                sys.exit(1)
            urls = []
            i += 1
            while i < len(args) and not args[i].startswith("-"):
                urls.append(args[i])
                i += 1
            if not urls:
                print("Usage: pikpak <folder> --url <url1> [url2] ...", file=sys.stderr)
                sys.exit(1)
        elif args[i] in ("-a", "--all"):
            select_all = True
            i += 1
        elif args[i] in ("-y", "--yes"):
            auto_yes = True
            i += 1
        else:
            remaining.append(args[i])
            i += 1
    if not remaining:
        print("Usage: pikpak <folder> [-f <file>] [--url <url1> ...] [-a] [-y]", file=sys.stderr)
        sys.exit(1)
    folder_name = remaining[0]

    # Start auth in background so user isn't blocked
    config = load_config()
    executor = concurrent.futures.ThreadPoolExecutor(max_workers=1)
    auth_future = executor.submit(_get_auth_blocking, config)
    # Collect user input while auth runs in background
    if urls:
        text = fetch_urls(urls)
    elif file_path:
        try:
            text = Path(file_path).read_text()
        except FileNotFoundError:
            print(f"File not found: {file_path}")
            sys.exit(1)
    else:
        print(f"\nPaste text containing magnet links, then press Ctrl+D:")
        try:
            text = sys.stdin.read()
        except KeyboardInterrupt:
            sys.exit(0)

    def _episode_key(pair):
        m = re.search(r'[Ss](\d+)[Ee](\d+)', pair[0])
        return (int(m.group(1)), int(m.group(2))) if m else (float('inf'), float('inf'))

    pairs = sorted(extract_magnets(text), key=_episode_key)
    if not pairs:
        print("No magnet links found.")
        sys.exit(0)

    print(f"\nFound {len(pairs)} magnet link(s).\n")

    # Build a title lookup for the submit log
    title_of = {magnet: title for title, magnet in pairs}

    if select_all or len(pairs) == 1:
        selected = [magnet for _, magnet in pairs]
    else:
        choices = [questionary.Choice(title=title, value=magnet) for title, magnet in pairs]
        selected = questionary.checkbox(
            f"Select to send to '{folder_name}'",
            choices=choices,
        ).ask()

    if not selected:
        print("Nothing selected.")
        sys.exit(0)

    # Now wait for auth (should be done by now)
    try:
        access_token = auth_future.result()
    except httpx.HTTPStatusError as e:
        print(f"Login failed: {e.response.status_code} {e.response.json().get('error_description', e.response.text)}")
        sys.exit(1)

    folder_id = find_folder_by_path(access_token, folder_name)
    if folder_id is None:
        print(f"Folder '{folder_name}' not found in PikPak.")
        if auto_yes or questionary.confirm(f"Create it?").ask():
            folder_id = create_folder(access_token, folder_name)
            print(f"Created folder '{folder_name}'")
        else:
            sys.exit(1)

    save_recent_dir(folder_name)

    print()
    for magnet in selected:
        print(f"Submitting: {title_of.get(magnet, magnet[:80])}")
        try:
            submit_magnet(access_token, magnet, folder_id)
            print("  OK")
        except httpx.HTTPStatusError as e:
            print(f"  ERROR {e.response.status_code}: {e.response.text}")


if __name__ == "__main__":
    main()
