import sys
import re
import json
import time
import getpass
import uuid
from html.parser import HTMLParser
from pathlib import Path
from urllib.parse import unquote_plus

import httpx
import keyring
import questionary

# PikPak app credentials (same ones rclone uses)
CLIENT_ID = "YNxT9w7GMdWvEOKa"
CLIENT_SECRET = "dbw2OtmVEeuUvIptb1Coyg"
KEYRING_SERVICE = "pikpak"

AUTH_BASE = "https://user.mypikpak.com"
API_BASE = "https://api-drive.mypikpak.com"

CONFIG_FILE = Path.home() / ".config" / "pikpak" / "config.json"
TOKEN_CACHE = Path.home() / ".cache" / "pikpak" / "tokens.json"


def load_config():
    config = {}

    if CONFIG_FILE.exists():
        config = json.loads(CONFIG_FILE.read_text())

        # migrate: remove plaintext password if it snuck in
        if "password" in config:
            password = config.pop("password")
            if not keyring.get_password(KEYRING_SERVICE, config.get("username", "")):
                keyring.set_password(KEYRING_SERVICE, config["username"], password)
            CONFIG_FILE.write_text(json.dumps(config, indent=2))
            print("Migrated password from config file to system keyring.")

    if "username" not in config:
        print(f"No config found at {CONFIG_FILE}")
        CONFIG_FILE.parent.mkdir(parents=True, exist_ok=True)
        config["username"] = input("PikPak username (email): ").strip()

    if "device_id" not in config:
        config["device_id"] = str(uuid.uuid4())

    password = keyring.get_password(KEYRING_SERVICE, config["username"])
    if not password:
        password = getpass.getpass("PikPak password: ")
        keyring.set_password(KEYRING_SERVICE, config["username"], password)
        print("Password saved to system keyring.")

    CONFIG_FILE.write_text(json.dumps(config, indent=2))
    CONFIG_FILE.chmod(0o600)

    config["password"] = password
    return config


def load_tokens():
    if TOKEN_CACHE.exists():
        return json.loads(TOKEN_CACHE.read_text())
    return None


def save_tokens(tokens):
    TOKEN_CACHE.parent.mkdir(parents=True, exist_ok=True)
    TOKEN_CACHE.write_text(json.dumps(tokens, indent=2))
    TOKEN_CACHE.chmod(0o600)


def get_captcha_token(device_id, username):
    resp = httpx.post(
        f"{AUTH_BASE}/v1/shield/captcha/init",
        json={
            "client_id": CLIENT_ID,
            "action": "POST:/v1/auth/signin",
            "device_id": device_id,
            "captcha_token": "",
            "meta": {"email": username},
        },
    )
    resp.raise_for_status()
    return resp.json().get("captcha_token", "")


def login(config):
    captcha_token = get_captcha_token(config["device_id"], config["username"])
    resp = httpx.post(
        f"{AUTH_BASE}/v1/auth/signin",
        json={
            "client_id": CLIENT_ID,
            "client_secret": CLIENT_SECRET,
            "username": config["username"],
            "password": config["password"],
            "captcha_token": captcha_token,
        },
    )
    resp.raise_for_status()
    data = resp.json()
    tokens = {
        "access_token": data["access_token"],
        "refresh_token": data["refresh_token"],
        "expires_at": time.time() + data.get("expires_in", 86400) - 60,
    }
    save_tokens(tokens)
    return tokens


def do_refresh(tokens):
    resp = httpx.post(
        f"{AUTH_BASE}/v1/auth/token",
        json={
            "client_id": CLIENT_ID,
            "client_secret": CLIENT_SECRET,
            "grant_type": "refresh_token",
            "refresh_token": tokens["refresh_token"],
        },
    )
    resp.raise_for_status()
    data = resp.json()
    new_tokens = {
        "access_token": data["access_token"],
        "refresh_token": data.get("refresh_token", tokens["refresh_token"]),
        "expires_at": time.time() + data.get("expires_in", 86400) - 60,
    }
    save_tokens(new_tokens)
    return new_tokens


def get_access_token(config):
    tokens = load_tokens()
    if tokens is None:
        print("Logging in...")
        tokens = login(config)
    elif time.time() > tokens["expires_at"]:
        print("Refreshing token...")
        try:
            tokens = do_refresh(tokens)
        except Exception:
            print("Refresh failed, logging in again...")
            tokens = login(config)
    return tokens["access_token"]


def list_files(access_token, parent_id=None):
    params = {"page_size": 100}
    if parent_id:
        params["parent_id"] = parent_id
    resp = httpx.get(
        f"{API_BASE}/drive/v1/files",
        headers={"Authorization": f"Bearer {access_token}"},
        params=params,
    )
    if resp.status_code == 404:
        return []
    resp.raise_for_status()
    return resp.json().get("files", [])


def find_folder(access_token, name, parent_id=None):
    files = list_files(access_token, parent_id)
    for f in files:
        if f["kind"] == "drive#folder" and f["name"] == name:
            return f["id"]
    return None


def find_folder_by_path(access_token, path):
    parts = path.strip("/").split("/")
    parent_id = None
    for part in parts:
        parent_id = find_folder(access_token, part, parent_id)
        if parent_id is None:
            return None
    return parent_id


def create_folder(access_token, name):
    resp = httpx.post(
        f"{API_BASE}/drive/v1/files",
        headers={"Authorization": f"Bearer {access_token}"},
        json={"kind": "drive#folder", "name": name},
    )
    resp.raise_for_status()
    return resp.json()["file"]["id"]


def submit_magnet(access_token, magnet, folder_id):
    resp = httpx.post(
        f"{API_BASE}/drive/v1/files",
        headers={"Authorization": f"Bearer {access_token}"},
        json={
            "kind": "drive#file",
            "upload_type": "UPLOAD_TYPE_URL",
            "url": {"url": magnet},
            "parent_id": folder_id,
        },
    )
    resp.raise_for_status()
    return resp.json()


class _MagnetParser(HTMLParser):
    def __init__(self):
        super().__init__()
        self.results = []  # list of (title, magnet_url)
        self._magnet = None
        self._texts = []

    def handle_starttag(self, tag, attrs):
        if tag == "a":
            href = dict(attrs).get("href", "")
            if href.startswith("magnet:"):
                self._magnet = href
                self._texts = []

    def handle_data(self, data):
        if self._magnet is not None:
            self._texts.append(data)

    def handle_endtag(self, tag):
        if tag == "a" and self._magnet is not None:
            text = " ".join(self._texts).strip()
            self.results.append((text, self._magnet))
            self._magnet = None


def _label_from_magnet(magnet):
    dn = re.search(r"[&?]dn=([^&]+)", magnet)
    if dn:
        return unquote_plus(dn.group(1))
    return magnet[:80]


def extract_magnets(text):
    """Return list of (title, magnet_url) pairs, deduped by URL."""
    parser = _MagnetParser()
    try:
        parser.feed(text)
    except Exception:
        pass

    if parser.results:
        seen = {}
        for title, magnet in parser.results:
            if magnet not in seen:
                seen[magnet] = title or _label_from_magnet(magnet)
        return [(title, magnet) for magnet, title in seen.items()]

    # fallback: plain text / no HTML anchor tags found
    pattern = r"magnet:\?[^\s\"'<>\]]+"
    magnets = list(dict.fromkeys(re.findall(pattern, text)))
    return [(_label_from_magnet(m), m) for m in magnets]


def cmd_ls(path=None):
    config = load_config()
    try:
        access_token = get_access_token(config)
    except httpx.HTTPStatusError as e:
        print(f"Login failed: {e.response.status_code} {e.response.json().get('error_description', e.response.text)}")
        sys.exit(1)

    parent_id = None
    if path:
        parent_id = find_folder_by_path(access_token, path)
        if parent_id is None:
            print(f"Folder '{path}' not found.")
            sys.exit(1)

    files = list_files(access_token, parent_id)
    if not files:
        print("(empty)")
        return
    for f in files:
        kind = "d" if f["kind"] == "drive#folder" else "f"
        print(f"[{kind}] {f['name']}")


def cmd_login():
    config = load_config()
    print(f"Logging in as {config['username']}...")
    try:
        login(config)
        print("Login successful.")
    except httpx.HTTPStatusError as e:
        print(f"Login failed: {e.response.status_code} {e.response.json().get('error_description', e.response.text)}")
        sys.exit(1)


def main():
    if len(sys.argv) < 2:
        print("Usage:", file=sys.stderr)
        print("  pikpak login               -- setup and verify credentials", file=sys.stderr)
        print("  pikpak ls [path]           -- list files/folders", file=sys.stderr)
        print("  pikpak <folder>            -- submit magnet links to a folder", file=sys.stderr)
        print("  e.g. pikpak dropbox/TV.Shows", file=sys.stderr)
        print("       pikpak dropbox/Movies", file=sys.stderr)
        sys.exit(1)

    if sys.argv[1] == "login":
        cmd_login()
        return

    if sys.argv[1] == "ls":
        cmd_ls(sys.argv[2] if len(sys.argv) > 2 else None)
        return

    folder_name = sys.argv[1]

    config = load_config()
    try:
        access_token = get_access_token(config)
    except httpx.HTTPStatusError as e:
        print(f"Login failed: {e.response.status_code} {e.response.json().get('error_description', e.response.text)}")
        sys.exit(1)

    folder_id = find_folder_by_path(access_token, folder_name)
    if folder_id is None:
        print(f"Folder '{folder_name}' not found in PikPak.")
        if questionary.confirm(f"Create it?").ask():
            folder_id = create_folder(access_token, folder_name)
            print(f"Created folder '{folder_name}'")
        else:
            sys.exit(1)

    print(f"\nPaste text containing magnet links, then press Ctrl+D:")
    try:
        text = sys.stdin.read()
    except KeyboardInterrupt:
        sys.exit(0)

    pairs = sorted(extract_magnets(text), key=lambda x: x[0].lower())
    if not pairs:
        print("No magnet links found.")
        sys.exit(0)

    print(f"\nFound {len(pairs)} magnet link(s).\n")

    # Build a title lookup for the submit log
    title_of = {magnet: title for title, magnet in pairs}

    if len(pairs) == 1:
        selected = [pairs[0][1]]
    else:
        choices = [questionary.Choice(title=title, value=magnet) for title, magnet in pairs]
        selected = questionary.checkbox(
            f"Select to send to '{folder_name}'",
            choices=choices,
        ).ask()

    if not selected:
        print("Nothing selected.")
        sys.exit(0)

    print()
    for magnet in selected:
        print(f"Submitting: {title_of.get(magnet, magnet[:80])}")
        try:
            submit_magnet(access_token, magnet, folder_id)
            print("  OK")
        except httpx.HTTPStatusError as e:
            print(f"  ERROR {e.response.status_code}: {e.response.text}")


if __name__ == "__main__":
    main()
